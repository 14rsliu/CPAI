/* app.wxss - 高级心理学配色系统 */

/* ===== 高级配色系统 - 参考心理学研究 ===== */
:page {
  /* 主色调 - 信任 teal (心理学：平静、专业、可信赖) */
  --primary-50: #F0FDFA;
  --primary-100: #CCFBF1;
  --primary-200: #99F6E4;
  --primary-300: #5EEAD4;
  --primary-400: #2DD4BF;
  --primary-500: #14B8A6;
  --primary-600: #0D9488;
  --primary-700: #0F766E;
  --primary-800: #115E59;
  --primary-900: #134E4A;
  
  /* 辅助色 - 温暖珊瑚 (心理学：友好、亲和) */
  --coral-50: #FEF2F2;
  --coral-100: #FEE2E2;
  --coral-200: #FECACA;
  --coral-300: #FCA5A5;
  --coral-400: #F87171;
  --coral-500: #EF4444;
  --coral-600: #DC2626;
  --coral-700: #B91C1C;
  --coral-800: #991B1B;
  --coral-900: #7F1D1D;
  
  /* 中性色 - 高级灰 (心理学：专业、平衡) */
  --gray-50: #FAFAFA;
  --gray-100: #F5F5F5;
  --gray-200: #E5E5E5;
  --gray-300: #D4D4D4;
  --gray-400: #A3A3A3;
  --gray-500: #737373;
  --gray-600: #525252;
  --gray-700: #404040;
  --gray-800: #262626;
  --gray-900: #171717;
  
  /* 强调色 - 深蓝 (心理学：智慧、深度) */
  --indigo-50: #EEF2FF;
  --indigo-100: #E0E7FF;
  --indigo-200: #C7D2FE;
  --indigo-300: #A5B4FC;
  --indigo-400: #818CF8;
  --indigo-500: #6366F1;
  --indigo-600: #4F46E5;
  --indigo-700: #4338CA;
  --indigo-800: #3730A3;
  --indigo-900: #312E81;
  
  /* 成功/警告/错误 */
  --success: #10B981;
  --success-dark: #059669;
  --warning: #F59E0B;
  --warning-dark: #D97706;
  --error: #EF4444;
  --error-dark: #DC2626;
  
  /* 渐变方案 - 苹果风格 */
  --gradient-primary: linear-gradient(135deg, #0F766E 0%, #14B8A6 100%);
  --gradient-warm: linear-gradient(135deg, #F472B6 0%, #FB7185 100%);
  --gradient-cool: linear-gradient(135deg, #6366F1 0%, #818CF8 100%);
  --gradient-sunset: linear-gradient(135deg, #FDBA74 0%, #FB923C 100%);
  --gradient-ocean: linear-gradient(135deg, #06B6D4 0%, #0891B2 100%);
  
  /* 间距系统 - 8px 基准 */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;
  --space-8: 64rpx;
  --space-10: 80rpx;
  --space-12: 96rpx;
  --space-16: 128rpx;
  
  /* 圆角系统 - 苹果风格 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-2xl: 28rpx;
  --radius-3xl: 36rpx;
  --radius-full: 9999rpx;
  
  /* 阴影系统 - 高级感 */
  --shadow-xs: 0 1rpx 2rpx rgba(0,0,0,0.04);
  --shadow-sm: 0 2rpx 4rpx rgba(0,0,0,0.06), 0 1rpx 2rpx rgba(0,0,0,0.03);
  --shadow-md: 0 4rpx 8rpx rgba(0,0,0,0.08), 0 2rpx 4rpx rgba(0,0,0,0.04);
  --shadow-lg: 0 10rpx 20rpx rgba(0,0,0,0.1), 0 4rpx 8rpx rgba(0,0,0,0.05);
  --shadow-xl: 0 20rpx 40rpx rgba(0,0,0,0.12), 0 8rpx 16rpx rgba(0,0,0,0.06);
  --shadow-2xl: 0 30rpx 60rpx rgba(0,0,0,0.14), 0 12rpx 24rpx rgba(0,0,0,0.08);
  --shadow-glow: 0 0 30rpx rgba(20,184,166,0.3);
  
  /* 排版系统 */
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 44rpx;
  --font-3xl: 56rpx;
  --font-4xl: 68rpx;
  
  /* 动效 - 苹果风格缓动 */
  --transition-instant: 100ms;
  --transition-fast: 200ms;
  --transition-base: 300ms;
  --transition-slow: 400ms;
  --transition-slower: 500ms;
  --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
  --ease-out-circ: cubic-bezier(0.075, 0.82, 0.165, 1);
  --ease-in-out-quad: cubic-bezier(0.45, 0, 0.55, 1);
}

/* ===== 全局重置 ===== */
page {
  background: linear-gradient(180deg, #F0FDFA 0%, #FAFAFA 100%);
  color: var(--gray-900);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-base);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

view, text, button {
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

button {
  border: none;
  outline: none;
  background: none;
  padding: 0;
  margin: 0;
  line-height: 1.5;
}

button::after {
  border: none;
}

/* ===== 工具类 ===== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }
.gap-1 { gap: var(--space-1); }
.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }
.gap-4 { gap: var(--space-4); }

.text-center { text-align: center; }
.text-sm { font-size: var(--font-sm); }
.text-base { font-size: var(--font-base); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-2xl { font-size: var(--font-2xl); }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.text-primary { color: var(--primary-700); }
.text-gray-400 { color: var(--gray-400); }
.text-gray-500 { color: var(--gray-500); }
.text-gray-600 { color: var(--gray-600); }
.text-gray-700 { color: var(--gray-700); }

.bg-white { background-color: white; }
.bg-gradient { background: var(--gradient-primary); }

.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-2xl { border-radius: var(--radius-2xl); }

.shadow-md { box-shadow: var(--shadow-md); }
.shadow-lg { box-shadow: var(--shadow-lg); }
.shadow-xl { box-shadow: var(--shadow-xl); }

.p-3 { padding: var(--space-3); }
.p-4 { padding: var(--space-4); }
.p-5 { padding: var(--space-5); }
.px-4 { padding-left: var(--space-4); padding-right: var(--space-4); }
.py-3 { padding-top: var(--space-3); padding-bottom: var(--space-3); }

.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mb-2 { margin-bottom: var(--space-2); }
.mb-3 { margin-bottom: var(--space-3); }
.mb-4 { margin-bottom: var(--space-4); }

/* ===== 高级渐变背景 ===== */
.gradient-primary {
  background: var(--gradient-primary);
}

.gradient-warm {
  background: var(--gradient-warm);
}

.gradient-cool {
  background: var(--gradient-cool);
}

.gradient-sunset {
  background: var(--gradient-sunset);
}

.gradient-ocean {
  background: var(--gradient-ocean);
}

/* ===== 高级卡片 - 苹果风格 ===== */
.card {
  background: white;
  border-radius: var(--radius-2xl);
  padding: var(--space-5);
  box-shadow: var(--shadow-lg);
  transition: all var(--transition-base) var(--ease-out-expo);
  border: 1rpx solid rgba(0,0,0,0.04);
}

.card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.card-glass {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
}

/* ===== 高级按钮 - 苹果风格 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4) var(--space-5);
  border-radius: var(--radius-xl);
  font-size: var(--font-base);
  font-weight: 600;
  transition: all var(--transition-base) var(--ease-out-expo);
  border: none;
  outline: none;
  cursor: pointer;
}

.btn:active {
  transform: scale(0.96);
}

.btn-primary {
  background: var(--gradient-primary);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(15,118,110,0.3);
}

.btn-primary:active {
  box-shadow: 0 4rpx 12rpx rgba(15,118,110,0.3);
}

.btn-secondary {
  background: var(--gray-100);
  color: var(--gray-700);
}

.btn-outline {
  background: white;
  color: var(--primary-600);
  border: 2rpx solid var(--primary-200);
}

.btn-block {
  width: 100%;
}

/* ===== 高级进度条 ===== */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: var(--gray-200);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  transition: width var(--transition-slower) var(--ease-out-expo);
}

/* ===== 高级标签 ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  font-weight: 600;
}

.badge-primary {
  background: var(--primary-100);
  color: var(--primary-800);
}

.badge-success {
  background: #D1FAE5;
  color: #065F46;
}

.badge-warning {
  background: #FEF3C7;
  color: #92400E;
}

.badge-error {
  background: #FEE2E2;
  color: #991B1B;
}

/* ===== 高级动画 - 苹果风格 ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.05); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.animate-fade-in {
  animation: fadeIn var(--transition-base) var(--ease-out-expo);
}

.animate-slide-up {
  animation: slideUp var(--transition-slow) var(--ease-out-expo);
}

.animate-slide-down {
  animation: slideDown var(--transition-slow) var(--ease-out-expo);
}

.animate-scale-in {
  animation: scaleIn var(--transition-base) var(--ease-out-expo);
}

.animate-pulse {
  animation: pulse 2s var(--ease-in-out-quad) infinite;
}

.animate-shimmer {
  background: linear-gradient(90deg, #F0FDFA 25%, #CCFBF1 50%, #F0FDFA 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

/* ===== 安全区域 ===== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 毛玻璃效果 ===== */
.glass {
  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.4);
}

/* ===== 名人卡片样式 ===== */
名人卡片
名人卡片 {
  background: linear-gradient(135deg, #FEF2F2 0%, #FFF5F5 100%);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  border: 1rpx solid var(--coral-100);
}
