<!--pages/index/index.wxml-->
<view class="container">
  <!-- 醒目 Banner -->
  <view class="banner">
    <view class="banner-fire">🔥</view>
    <view class="banner-text">AI时代已来！孩子究竟适合什么职业？</view>
    <view class="banner-sub">测一测性格指数，AI帮你规划未来不被淘汰</view>
  </view>

  <view class="header">
    <view class="title">🗼 职业偏好 & AI 适配测试</view>
    <view class="subtitle">探索你的职业方向，了解 AI 时代的发展机会</view>
  </view>

  <!-- 角色选择 -->
  <view class="role-selector">
    <view class="role-card {{userRole === 'parent' ? 'selected' : ''}}" bindtap="selectRole" data-role="parent">
      <view class="role-emoji">👨‍👩‍👧</view>
      <view class="role-name">家长模式</view>
      <view class="role-desc">给您的孩子测一测</view>
    </view>
    <view class="role-card {{userRole === 'student' ? 'selected' : ''}}" bindtap="selectRole" data-role="student">
      <view class="role-emoji">🎓</view>
      <view class="role-name">学生模式</view>
      <view class="role-desc">帮我选专业</view>
    </view>
  </view>

  <view class="test-list">
    <view class="test-card {{item.completed ? 'completed' : ''}}" bindtap="startTest" data-type="{{item.id}}" wx:for="{{tests}}" wx:key="id">
      <view class="card-icon">{{item.icon}}</view>
      <view class="card-content">
        <view class="card-title">{{item.id === 'aiReplace' && userRole === 'student' ? item.studentTitle : (item.parentTitle || item.name)}}</view>
        <view class="card-desc">{{item.id === 'aiReplace' && userRole === 'student' ? item.studentDesc : (item.parentDesc || item.desc || '')}}</view>
        <view class="card-info" wx:if="{{item.id === 'personality'}}">20 题 · 约 3 分钟</view>
        <view class="card-info" wx:elif="{{item.id === 'careerPrefer'}}">30 题 · 约 5 分钟</view>
        <view class="card-info" wx:elif="{{item.id === 'aiFit'}}">15 题 · 约 3 分钟</view>
        <view class="card-info" wx:elif="{{item.id === 'aiReplace'}}">10 题 · 约 2 分钟</view>
        <view class="card-info" wx:elif="{{item.id === 'aiUsage'}}">5 题 · 约 1 分钟</view>
      </view>
      <view class="card-arrow">></view>
    </view>
  </view>

  <view class="footer">
    <view class="footer-text">{{footerText}}</view>
  </view>
</view>
