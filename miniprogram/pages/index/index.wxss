/* pages/index/index.wxss - 专业 UI 设计 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: calc(var(--status-bar-height) + 20rpx) 30rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.container::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
  pointer-events: none;
}

.container::after {
  content: '';
  position: absolute;
  bottom: -150rpx;
  left: -150rpx;
  width: 500rpx;
  height: 500rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
  pointer-events: none;
}

/* 醒目 Banner */
.banner {
  text-align: center;
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.25) 0%, rgba(255,255,255,0.1) 100%);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255,255,255,0.3);
  position: relative;
  z-index: 1;
  animation: bannerPulse 3s ease-in-out infinite;
}

@keyframes bannerPulse {
  0%, 100% { transform: scale(1); box-shadow: 0 8rpx 30rpx rgba(255,200,50,0.2); }
  50% { transform: scale(1.015); box-shadow: 0 12rpx 40rpx rgba(255,200,50,0.4); }
}

.banner-fire {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  animation: fireShake 0.6s ease-in-out infinite;
}

@keyframes fireShake {
  0%, 100% { transform: rotate(-3deg) scale(1); }
  50% { transform: rotate(3deg) scale(1.1); }
}

.banner-text {
  font-size: 34rpx;
  font-weight: 700;
  color: white;
  line-height: 1.5;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.banner-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
  font-weight: 400;
}

/* 角色选择 */
.role-selector {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
  animation: slideUp 0.6s var(--ease-out) 0.05s both;
}

.role-card {
  flex: 1;
  background: rgba(255,255,255,0.9);
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  border: 3rpx solid transparent;
  transition: all 0.3s var(--ease-out);
  backdrop-filter: blur(10rpx);
}

.role-card:active {
  transform: scale(0.97);
}

.role-card.selected {
  background: rgba(255,255,255,1);
  border-color: #FFD700;
  box-shadow: 0 8rpx 30rpx rgba(255,215,0,0.35);
  transform: scale(1.03);
}

.role-emoji {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.role-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.role-desc {
  font-size: 22rpx;
  color: #888;
}

/* 头部区域 */
.header {
  text-align: center;
  margin-bottom: 48rpx;
  color: white;
  position: relative;
  z-index: 1;
  animation: slideUp 0.6s var(--ease-out);
}

.logo-wrapper {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.logo {
  font-size: 64rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: -0.5rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.92;
  font-weight: 400;
  max-width: 500rpx;
  margin: 0 auto;
  line-height: 1.5;
}

/* 测试列表 */
.test-list {
  background: rgba(255,255,255,0.96);
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  backdrop-filter: blur(20rpx);
  position: relative;
  z-index: 1;
  animation: slideUp 0.7s var(--ease-out) 0.1s both;
}

.test-card {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #ffffff 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  transition: all 0.25s var(--ease-out);
  border: 2rpx solid transparent;
  position: relative;
  overflow: hidden;
}

.test-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 6rpx;
  background: linear-gradient(180deg, var(--gradient-start), var(--gradient-end));
  opacity: 0;
  transition: opacity 0.25s var(--ease-out);
}

.test-card:last-child {
  margin-bottom: 0;
}

.test-card:active {
  transform: scale(0.97) translateX(-4rpx);
  background: linear-gradient(135deg, #f0f2ff 0%, #ffffff 100%);
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.2);
}

.test-card:active::before {
  opacity: 1;
}

.test-card.completed {
  background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 100%);
}

.test-card.completed::before {
  opacity: 1;
  background: linear-gradient(180deg, #10b981, #059669);
}

.card-icon {
  font-size: 64rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
  transition: transform 0.25s var(--ease-out);
}

.test-card:active .card-icon {
  transform: scale(1.1) rotate(5deg);
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gray-900);
  margin-bottom: 8rpx;
  letter-spacing: -0.3rpx;
}

.card-desc {
  font-size: 24rpx;
  color: var(--gray-500);
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-info {
  font-size: 22rpx;
  color: var(--gray-400);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.card-info::before {
  content: '⏱';
  font-size: 20rpx;
}

.card-arrow {
  font-size: 36rpx;
  color: var(--gray-300);
  margin-left: 20rpx;
  transition: all 0.25s var(--ease-out);
}

.test-card:active .card-arrow {
  color: var(--primary-500);
  transform: translateX(4rpx);
}

/* 完成标记 */
.completed-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  color: white;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(16,185,129,0.3);
}

/* 底部区域 */
.footer {
  margin-top: 48rpx;
  text-align: center;
  position: relative;
  z-index: 1;
  animation: fadeIn 0.8s var(--ease-out) 0.2s both;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.15);
  padding: 20rpx 32rpx;
  border-radius: var(--radius-full);
  display: inline-block;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255,255,255,0.2);
}

/* 进度指示器 */
.progress-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 32rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  transition: all 0.3s var(--ease-out);
}

.dot.active {
  background: white;
  width: 32rpx;
  border-radius: 6rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: white;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 28rpx;
  opacity: 0.9;
  line-height: 1.6;
}
